---
/**
 * A reusable lightbox using the native <dialog> element for viewing images
 * at full size with zoom and pan.
 * Include once on the page. Call `window.__openLightbox(src, alt)` from anywhere.
 */
---

<dialog class="lightbox-dialog" id="image-lightbox">
	<button class="lightbox-close" aria-label="Close lightbox">&times;</button>
	<div class="lightbox-content">
		<img id="lightbox-img" src="" alt="" />
	</div>
</dialog>

<script>
	import { $lightboxState, closeLightbox } from "../store/uiStore";

	const dialog = document.getElementById(
		"image-lightbox"
	) as HTMLDialogElement;
	const img = document.getElementById("lightbox-img") as HTMLImageElement;
	const closeBtn = dialog.querySelector(".lightbox-close")!;

	let scale = 1;
	let isDragging = false;
	let startX = 0;
	let startY = 0;
	let translateX = 0;
	let translateY = 0;

	$lightboxState.subscribe((state) => {
		if (state) {
			img.src = state.src;
			img.alt = state.alt;
			scale = 1;
			translateX = 0;
			translateY = 0;
			img.style.transform = `scale(1) translate(0px, 0px)`;
			if (!dialog.open) {
				dialog.showModal();
			}
		} else {
			if (dialog.open) {
				dialog.close();
			}
		}
	});

	closeBtn.addEventListener("click", () => closeLightbox());

	// Close on backdrop click (native dialog gives us this with ::backdrop)
	dialog.addEventListener("click", (e) => {
		if (e.target === dialog) closeLightbox();
	});

	// Sync state when dialog closes natively (e.g. via Escape key)
	dialog.addEventListener("close", () => {
		closeLightbox();
	});

	// Zoom with scroll wheel
	dialog.addEventListener("wheel", (e) => {
		e.preventDefault();
		const delta = e.deltaY > 0 ? -0.15 : 0.15;
		scale = Math.min(Math.max(0.5, scale + delta), 5);
		img.style.transform = `scale(${scale}) translate(${translateX}px, ${translateY}px)`;
	});

	// Pan with drag
	img.addEventListener("mousedown", (e) => {
		if (scale <= 1) return;
		isDragging = true;
		startX = e.clientX - translateX;
		startY = e.clientY - translateY;
		img.style.cursor = "grabbing";
	});

	window.addEventListener("mousemove", (e) => {
		if (!isDragging) return;
		translateX = e.clientX - startX;
		translateY = e.clientY - startY;
		img.style.transform = `scale(${scale}) translate(${translateX}px, ${translateY}px)`;
	});

	window.addEventListener("mouseup", () => {
		isDragging = false;
		img.style.cursor = scale > 1 ? "grab" : "zoom-in";
	});
</script>

<style>
	.lightbox-dialog {
		border: none;
		background: transparent;
		max-width: 90vw;
		max-height: 90vh;
		padding: 0;
		overflow: visible;
	}

	.lightbox-dialog::backdrop {
		background: rgba(0, 0, 0, 0.9);
		backdrop-filter: blur(10px);
	}

	.lightbox-close {
		position: fixed;
		top: 1em;
		right: 1.5em;
		background: none;
		border: none;
		color: white;
		font-size: 2.5rem;
		cursor: pointer;
		z-index: 10000;
		line-height: 1;
		opacity: 0.7;
		transition: opacity 0.2s ease;
	}

	.lightbox-close:hover {
		opacity: 1;
	}

	.lightbox-content {
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.lightbox-content img {
		max-width: 85vw;
		max-height: 85vh;
		object-fit: contain;
		border-radius: 8px;
		cursor: zoom-in;
		transition: transform 0.15s ease;
		user-select: none;
		-webkit-user-drag: none;
	}
</style>
