---
type Props = {
	title: string;
	event: string;
	image: {
		href: string;
		alt: string;
	};
	links: {
		href: string;
		text: string;
	}[];
};
const { title, event, image, links } = Astro.props;
---

<div class="card">
	<div class="card-name">{title}</div>
	<div class="card-event">at {event}</div>

	<div class="card-image">
		<img loading="lazy" src={image.href} alt={image.alt} data-lightbox />
	</div>

	<div class="card-links">
		{
			links.map((link, i) => (
				<>
					<a href={link.href} target="_blank" rel="noreferrer">
						{link.text}
					</a>
					{i < links.length - 1 ? " · " : ""}
				</>
			))
		}
	</div>
</div>

<style>
	.card {
		break-inside: avoid;
		background-color: var(--card-bg);
		padding: 1.5em;
		border: var(--card-border);
		border-radius: var(--card-radius);
		backdrop-filter: blur(8px);
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
		transition: transform 0.3s ease, box-shadow 0.3s ease,
			border-color 0.3s ease;
		margin-bottom: 1.5em;
	}

	.card:hover {
		transform: translateY(-2px);
		box-shadow: 0 12px 40px var(--glow-color);
		border-color: rgba(136, 211, 255, 0.3);
	}

	.card-name {
		font-weight: 600;
		font-size: clamp(18px, 2vw, 22px);
		line-height: 1.3;
		margin-bottom: 0.4em;
	}

	.card-links {
		font-size: clamp(15px, 1.6vw, 18px);
		margin-bottom: 0.6em;
	}

	.card-links a {
		text-decoration-color: rgba(255, 255, 255, 0.3);
		transition: color 0.2s ease;
	}

	.card-links a:hover {
		color: var(--accent-color);
	}

	.card-event {
		font-size: clamp(15px, 1.6vw, 18px);
		color: var(--accent-color);
		margin-bottom: 0.8em;
	}

	.card-image {
		width: 100%;
		border-radius: 8px;
		overflow: hidden;
		margin-bottom: 0.8em;
	}

	.card-image img {
		width: 100%;
		height: 160px;
		object-fit: contain;
		cursor: pointer;
		transition: transform 0.3s ease;
		background: rgba(255, 255, 255, 0.03);
		border-radius: 8px;
	}

	.card-image img:hover {
		transform: scale(1.03);
	}

	@media screen and (max-width: 900px) {
		.card {
			padding: 1.1em;
		}

		.card-header {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.3em;
		}

		.card-image img {
			max-height: 150px;
		}
	}
</style>
